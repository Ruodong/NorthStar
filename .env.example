POSTGRES_PASSWORD=northstar_dev

# EGM source database (for one-time sync of master data)
EGM_PG_HOST=localhost
EGM_PG_PORT=5433
EGM_PG_DB=egm_local
EGM_PG_USER=postgres
EGM_PG_PASSWORD=postgres

# Confluence (optional — leave blank to use local file fallback)
CONFLUENCE_BASE_URL=https://km.xpaas.lenovo.com
CONFLUENCE_TOKEN=
CONFLUENCE_SPACE_KEY=ARD

# LLM (optional — falls back to rule-based scoring when disabled)
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o

# S3 attachment storage (optional — disabled by default, backend falls back
# to local filesystem). Shares the Lenovo OSS2 gateway with EGM; NorthStar
# uses an independent prefix. See .specify/features/s3-attachments/spec.md.
S3_ENABLED=false
S3_ENDPOINT=https://oss2.xcloud.lenovo.com:10443
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=lenovo-it
S3_PREFIX=pm/northstar/attachments
