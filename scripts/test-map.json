      "e2e": ["e2e-tests/confluence.spec.ts"]
    },
    "frontend/src/app/admin/applications/[app_id]/": {
      "e2e": ["e2e-tests/application-detail.spec.ts"]
    },
    "frontend/src/app/admin/projects/[project_id]/": {
      "e2e": ["e2e-tests/project-detail.spec.ts"]
    }
  },
  "scripts": {
    "scripts/sync_from_egm.py": {
      "api": ["api-tests/test_masters.py"]
    },
    "scripts/scan_confluence.py": {
      "api": [
