    "backend/app/routers/aliases.py": {
      "api": ["api-tests/test_aliases.py"]
    },
    "backend/app/services/graph_query.py": {
      "api": ["api-tests/test_ontology.py", "api-tests/test_graph.py"]
    },
    "backend/app/services/graph_client.py": {
      "api": ["api-tests/test_unit_graph_client.py", "api-tests/test_ontology.py"]
