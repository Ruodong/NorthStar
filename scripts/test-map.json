{
  "_comment": "Maps source files to their test files. PostToolUse hook reads this and runs only affected tests after each Edit/Write. Keep entries stable — when a new source file appears, add it here BEFORE writing tests for it.",
  "_version": 1,
  "backend": {
    "backend/app/routers/graph.py": {
      "api": ["api-tests/test_graph.py", "api-tests/test_ontology.py"]
